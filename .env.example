# Codex Bridge — Feishu & Telegram Integration

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of allowed Telegram user IDs
ALLOWED_TELEGRAM_IDS=123456789

# ---- Feishu (飞书) ----
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key

# Comma-separated list of allowed Feishu user open_ids
ALLOWED_FEISHU_IDS=ou_xxxxxxxxxxxx

# ---- Webhook Server (for Feishu) ----
WEBHOOK_PORT=9800
WEBHOOK_HOST=127.0.0.1

# ---- Codex ----
CODEX_MODEL=gpt-5.4-mini
CODEX_WORKING_DIR=~/codex-workspace
CODEX_BIN=/usr/bin/codex
# Initial timeout in ms (default: 300000 = 5 min). Auto-extends while Codex is active.
CODEX_TIMEOUT_MS=300000

# ---- Copilot ----
COPILOT_MODEL=gpt-5-mini
COPILOT_BIN=/usr/local/bin/copilot
COPILOT_TIMEOUT_MS=600000
COPILOT_AUTOPILOT=true
COPILOT_ALLOW_ALL=true

# ---- Engine ----
# Default backend engine: codex | copilot
DEFAULT_ENGINE=codex

# ---- Session ----
SESSION_DIR=~/codex-workspace/sessions
SESSION_MAX_AGE_HOURS=168

# ---- Security ----
RATE_LIMIT_PER_MINUTE=30

# ---- Speech-to-Text (STT) ----
# Provider: groq | openai | openrouter | local | none
STT_PROVIDER=none
# API key for the chosen provider (not needed for "local" or "none")
STT_API_KEY=
# Model name (defaults: groq=whisper-large-v3-turbo, openai=whisper-1, local=base)
STT_MODEL=
# Custom endpoint URL (optional, auto-detected for groq/openai/openrouter)
STT_ENDPOINT=
# Path to local whisper binary (only for provider=local)
STT_LOCAL_BIN=whisper
# Language hint (ISO 639-1 code, e.g. "zh", "en", "ja"; empty=auto-detect)
STT_LANGUAGE=

# ---- Logging ----
LOG_LEVEL=info
LOG_FILE=./logs/codex-bridge.log
